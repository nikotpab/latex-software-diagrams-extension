\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{softdiagrams}[2026/04/23 v0.1 Software Diagrams for LaTeX (UML 2.5)]

% --- Requirements ---
\RequirePackage{tikz}
\RequirePackage{pgfkeys}
\RequirePackage{ifthen}
\RequirePackage{xcolor}

% --- TikZ Libraries ---
\usetikzlibrary{arrows.meta, backgrounds, calc, fit, positioning, shapes.geometric, shapes.multipart, shadows, patterns}

% --- Global Styles and Configuration ---
\pgfkeys{
  /softdiag/.is family, /softdiag/.search also={/tikz},
  default/.style={
    line width=0.8pt,
    font=\small\sffamily,
    color=black,
    fill=white,
    rounded corners=1pt
  }
}

% Common Shadow Style
\tikzset{
  sd shadow/.style={drop shadow={opacity=0.3, shadow xshift=1pt, shadow yshift=-1pt}}
}

% --- 1. Class Diagrams ---
\tikzset{
  sd class/.style={
    rectangle split, rectangle split parts=3, 
    draw, fill=white, inner sep=3mm, text centered,
    sd shadow
  }
}
\newcommand{\sdClass}[5][]{
  \node[sd class, #1] (#2) {
    \textbf{#3}
    \nodepart{second} \raggedright #4
    \nodepart{third} \raggedright #5
  };
}

% --- 2. Object Diagrams ---
\tikzset{
  sd object/.style={
    rectangle, draw, fill=white, inner sep=3mm, text centered, sd shadow
  }
}
\newcommand{\sdObject}[3][]{
  \node[sd object, #1] (#2) {\underline{#3}};
}

% --- 3. Component Diagrams ---
\tikzset{
  sd component/.style={
    rectangle, draw, fill=white, minimum width=2.5cm, minimum height=1.5cm, sd shadow,
    append after command={
       (\mainnode.north west) ++(2mm,-2mm) node [draw, fill=white, minimum width=5mm, minimum height=2mm, anchor=north west, inner sep=0] {}
       (\mainnode.north west) ++(2mm,-5mm) node [draw, fill=white, minimum width=5mm, minimum height=2mm, anchor=north west, inner sep=0] {}
    }
  }
}
\newcommand{\sdComponent}[3][]{
  \node[sd component, #1] (#2) {#3};
}

% --- 4. Package Diagrams ---
\tikzset{
  sd package/.style={
    rectangle, draw, fill=white, minimum width=2.5cm, minimum height=1.5cm, sd shadow,
    label={[draw, fill=white, rectangle, anchor=south west, xshift=0pt, yshift=-0.8pt, inner sep=2pt]north west:\textbf{#3}}
  }
}
\newcommand{\sdPackage}[3][]{
  \node[sd package, #1] (#2) {};
}

% --- 5. Use Case Diagrams ---
\tikzset{
  sd usecase/.style={ellipse, draw, fill=white, inner sep=3mm, sd shadow},
}
\newcommand{\sdActor}[2][]{
  \node[inner sep=0, #1] (#2) {
    \begin{tabular}{c}
    \begin{tikzpicture}[scale=0.4]
      \draw[thick] (0,0) circle (0.3); % Head
      \draw[thick] (0,-0.3) -- (0,-1); % Body
      \draw[thick] (-0.5,-0.5) -- (0.5,-0.5); % Arms
      \draw[thick] (0,-1) -- (-0.4,-1.6); % Left Leg
      \draw[thick] (0,-1) -- (0.4,-1.6); % Right Leg
    \end{tikzpicture} \\
    #2
    \end{tabular}
  };
}
\newcommand{\sdUseCase}[3][]{
  \node[sd usecase, #1] (#2) {#3};
}

% --- 6. Activity Diagrams ---
\tikzset{
  sd activity/.style={rectangle, rounded corners=0.3cm, draw, fill=white, inner sep=3mm},
  sd decision/.style={diamond, draw, fill=white, aspect=2, inner sep=2pt},
  sd start/.style={circle, fill=black, minimum size=4mm},
  sd end/.style={circle, draw, line width=1pt, minimum size=6mm, append after command={node[circle, fill=black, minimum size=3mm] at (\mainnode.center) {}}},
  sd fork/.style={rectangle, fill=black, minimum width=2cm, minimum height=1mm},
  sd join/.style={rectangle, fill=black, minimum width=2cm, minimum height=1mm}
}
\newcommand{\sdActivity}[3][]{ \node[sd activity, #1] (#2) {#3}; }
\newcommand{\sdDecision}[2][]{ \node[sd decision, #1] (#2) {}; }

% --- 7. State Machine Diagrams ---
\tikzset{
  sd state/.style={rectangle, rounded corners=0.2cm, draw, fill=white, inner sep=3mm}
}
\newcommand{\sdState}[3][]{ \node[sd state, #1] (#2) {#3}; }

% --- 8. Deployment Diagrams ---
\tikzset{
  sd node/.style={
    draw, fill=white, sd shadow, minimum width=2cm, minimum height=1.5cm,
    path picture={
        \draw (path picture bounding box.north west) -- ++(0.2,0.2) -- ($(path picture bounding box.north east)+(0.2,0.2)$) -- (path picture bounding box.north east);
        \draw ($(path picture bounding box.north east)+(0.2,0.2)$) -- ++(0,-1.5) -- (path picture bounding box.south east);
    }
  }
}
\newcommand{\sdNode}[3][]{ \node[sd node, #1] (#2) {#3}; }

% --- 9. Sequence Diagrams ---
\newcommand{\sdLifeline}[3][]{
  \node[rectangle, draw, fill=white, sd shadow, #1] (#2) {#3};
  \draw[dashed] (#2.south) -- +(0,-6cm) coordinate (#2-bot);
}
\newcommand{\sdMessage}[4][]{
  \draw[sd assoc, -Stealth, #1] ([yshift=-#4] #2.south) -- ([yshift=-#4] #3.south);
}

% --- 10. Communication Diagrams ---
\tikzset{
  sd comm/.style={sd object}
}
\newcommand{\sdCommNode}[3][]{ \node[sd comm, #1] (#2) {#3}; }
\newcommand{\sdCommMessage}[5][]{
  \draw[sd assoc, #1] (#2) -- (#3) node[midway, sloped, above] {#4 \ifthenelse{\equal{#5}{forward}}{$\rightarrow$}{$\leftarrow$}};
}

% --- 11. Interaction Overview & Frames ---
\tikzset{
  sd frame/.style={draw, rectangle, inner sep=5mm, sd shadow}
}
\newcommand{\sdFrame}[3][]{ 
  \node[sd frame, #1] (#2) [label={[draw, fill=white, anchor=north west, xshift=2mm, yshift=-0.8pt, inner sep=2pt]north west:\textbf{#3}}] {}; 
}

% --- 12. Composite Structure ---
\tikzset{
  sd part/.style={rectangle, draw, fill=white, inner sep=3mm, sd shadow},
  sd port/.style={rectangle, draw, fill=black, minimum size=2mm, inner sep=0}
}
\newcommand{\sdPart}[3][]{ \node[sd part, #1] (#2) {#3}; }
\newcommand{\sdPort}[3][]{ \node[sd port, #1] (#2) at (#3) {}; }

% --- 13. Profile Diagrams ---
\tikzset{
  sd profile/.style={sd package, postaction={pattern=north east lines, pattern color=gray!20, opacity=0.3}},
  sd stereotype/.style={font=\itshape\small, label={[yshift=-4mm]center:$\ll$#1$\gg$}}
}

% --- 14. Timing Diagrams ---
\newcommand{\sdTimingLine}[3][]{
  \draw[thick, #1] (#2) -- ++(1,0) -- ++(0,1) -- ++(2,0) -- ++(0,-1) -- ++(1,0) node[right] {#3};
}

% --- Relationships (Universal) ---
\tikzset{
  sd assoc/.style={-},
  sd nav/.style={-Stealth},
  sd gen/.style={-{Triangle[open, length=8pt, width=8pt]}},
  sd real/.style={-{Triangle[open, length=8pt, width=8pt]}, dashed},
  sd dep/.style={-{Stealth}, dashed},
  sd comp/.style={-{Diamond[length=10pt, width=6pt]}},
  sd agg/.style={-{Diamond[open, length=10pt, width=6pt]}}
}

\endinput
